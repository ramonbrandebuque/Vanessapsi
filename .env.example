# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# -------------------------------------------------------------
# Configurações de E-mail (SMTP) para o Formulário de Contato
# -------------------------------------------------------------
# Endereço do servidor SMTP da sua hospedagem (ex: smtp.hostinger.com)
SMTP_HOST=""

# Porta SMTP (normalmente 465 para SSL ou 587 para TLS)
SMTP_PORT="465"

# Seu e-mail de envio (ex: contato@seusite.com.br)
SMTP_USER=""

# A senha do seu e-mail de envio
SMTP_PASS=""

# O e-mail que VAI RECEBER as mensagens do formulário. 
# Se for o mesmo usado no SMTP_USER, pode deixar em branco.
CONTACT_EMAIL=""
